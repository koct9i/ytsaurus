# https://diplodoc.com/docs/ru/settings
# https://diplodoc.com/docs/en/settings

lint: true

allowHtml: true
applyPresets: true
varsPreset: public
langs: ['en', 'ru']
allowCustomResources: true

mtimes: true
supportGithubAnchors: true

vcs:
  enabled: true
  remoteBase: https://github.com/koct9i/ytsaurus/tree/pain/yt/docs

extensions:
  - name: github-vcs

docs-viewer:
  project-name: YTsaurus
  show-revision: true
  land: en
  langs: ['en', 'ru']
  themes: ['dark', 'light']
  github-url-prefix: https://github.com/ytsaurus/ytsaurus/tree/main/yt/docs
  favicon-src: https://ytsaurus.tech/favicon/favicon.svg
  logo-options:
    title: YTsaurus
    url:
      en: https://ytsaurus.tech/
      default: https://ytsaurus.tech/{lang}
    src: https://ytsaurus.tech/assets/logo-light.svg
    src-dark: https://ytsaurus.tech/assets/logo-dark.svg
    src-preview:
      ru: https://ytsaurus.tech/assets/ru/docs/sharing.png
      default: https://ytsaurus.tech/assets/en/docs/sharing.png
    img-has:
      offset: true
      height: 34px

  index-page:
    hidden: true
    title: YT-public
    description: "YTsaurus public docs"

resources:
  csp:
    - connect-src:
        - https://*.algolia.net
        - https://*.algolianet.com
    - img-src:
        - https://ytsaurus.tech
        - https://storage.yandexcloud.net

search:
  provider: local
  tolerance: 2
  confidense: phrased
